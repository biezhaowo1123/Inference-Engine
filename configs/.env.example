# ============================================================
# Inference Engine - Configuration Example
# ============================================================
# Copy this file to .env and fill in your API keys
# cp configs/.env.example .env
# ============================================================

# ==================== Server Configuration ====================
SERVER_PORT=8080
SERVER_MODE=debug

# ==================== Database Configuration ====================
DB_TYPE=sqlite
# DB_TYPE=postgres
DB_NAME=inference.db
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=

# ==================== Model Configuration ====================
# Default model to use
DEFAULT_MODEL=deepseek

# ============================================================
# International Models
# ============================================================

# ---------- DeepSeek ----------
# https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_ENABLED=false

# ---------- Claude (Anthropic) ----------
# https://console.anthropic.com/
CLAUDE_API_KEY=your_claude_api_key
CLAUDE_BASE_URL=https://api.anthropic.com/v1
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_ENABLED=false

# ---------- GPT (OpenAI) ----------
# https://platform.openai.com/
GPT_API_KEY=your_openai_api_key
GPT_BASE_URL=https://api.openai.com/v1
GPT_MODEL=gpt-4o
GPT_ENABLED=false

# ---------- Gemini (Google) ----------
# https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_ENABLED=false

# ---------- Grok (xAI) ----------
# https://x.ai/
GROK_API_KEY=your_grok_api_key
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-beta
GROK_ENABLED=false

# ---------- Mistral ----------
# https://mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-large-latest
MISTRAL_ENABLED=false

# ============================================================
# Chinese Tech Giants
# ============================================================

# ---------- Qwen (Alibaba) ----------
# https://dashscope.console.aliyun.com/
QWEN_API_KEY=your_qwen_api_key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_ENABLED=false

# ---------- GLM (Zhipu AI) ----------
# https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4
GLM_ENABLED=false

# ---------- Wenxin (Baidu) ----------
# https://console.bce.baidu.com/qianfan/
WENXIN_API_KEY=your_wenxin_api_key
WENXIN_BASE_URL=https://aip.baidubce.com/rpc/2.0/ai_custom/v1/wenxinworkshop
WENXIN_MODEL=ernie-4.0-8k
WENXIN_ENABLED=false

# ---------- Hunyuan (Tencent) ----------
# https://cloud.tencent.com/product/hunyuan
HUNYUAN_API_KEY=your_hunyuan_api_key
HUNYUAN_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1
HUNYUAN_MODEL=hunyuan-lite
HUNYUAN_ENABLED=false

# ---------- Spark (iFlytek) ----------
# https://xinghuo.xfyun.cn/
SPARK_API_KEY=your_spark_api_key
SPARK_BASE_URL=https://spark-api-open.xf-yun.com/v1
SPARK_MODEL=generalv3.5
SPARK_ENABLED=false

# ---------- Doubao (ByteDance) ----------
# https://www.volcengine.com/product/doubao
DOUBAO_API_KEY=your_doubao_api_key
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-pro-32k
DOUBAO_ENABLED=false

# ============================================================
# Chinese Startups
# ============================================================

# ---------- MiniMax ----------
# https://api.minimax.chat/
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-M2.5
MINIMAX_ENABLED=false

# ---------- Moonshot ----------
# https://platform.moonshot.cn/
MOONSHOT_API_KEY=your_moonshot_api_key
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot-v1-8k
MOONSHOT_ENABLED=false

# ---------- Baichuan ----------
# https://platform.baichuan-ai.com/
BAICHUAN_API_KEY=your_baichuan_api_key
BAICHUAN_BASE_URL=https://api.baichuan-ai.com/v1
BAICHUAN_MODEL=Baichuan4
BAICHUAN_ENABLED=false

# ---------- Yi (01.AI) ----------
# https://platform.lingyiwanwu.com/
YI_API_KEY=your_yi_api_key
YI_BASE_URL=https://api.lingyiwanwu.com/v1
YI_MODEL=yi-large
YI_ENABLED=false

# ============================================================
# Other Platforms
# ============================================================

# ---------- Perplexity ----------
# https://www.perplexity.ai/
PERPLEXITY_API_KEY=your_perplexity_api_key
PERPLEXITY_BASE_URL=https://api.perplexity.ai
PERPLEXITY_MODEL=llama-3.1-sonar-large-128k-online
PERPLEXITY_ENABLED=false

# ---------- Cohere ----------
# https://cohere.ai/
COHERE_API_KEY=your_cohere_api_key
COHERE_BASE_URL=https://api.cohere.ai/v1
COHERE_MODEL=command-r-plus
COHERE_ENABLED=false

# ---------- Together AI ----------
# https://together.ai/
TOGETHER_API_KEY=your_together_api_key
TOGETHER_BASE_URL=https://api.together.xyz/v1
TOGETHER_MODEL=meta-llama/Llama-3-70b-chat-hf
TOGETHER_ENABLED=false

# ---------- OpenRouter ----------
# https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_ENABLED=false

# ============================================================
# Local Models (Free)
# ============================================================

# ---------- Ollama ----------
# https://ollama.ai/
# Install: curl -fsSL https://ollama.ai/install.sh | sh
# Usage: ollama pull qwen2.5:7b
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_ENABLED=false

# ---------- vLLM ----------
# https://github.com/vllm-project/vllm
# Install: pip install vllm
VLLM_API_KEY=
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=
VLLM_ENABLED=false

# ---------- LocalAI ----------
# https://localai.io/
# Install: docker run localai/localai
LOCALAI_API_KEY=
LOCALAI_BASE_URL=http://localhost:8080/v1
LOCALAI_MODEL=
LOCALAI_ENABLED=false
